---
interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const isSpanish = lang === 'es';
---

<header id="header">
  <nav class="container">
    <a href={isSpanish ? '/' : '/en/'} class="logo">
      <img src="/images/cls-logo.png" alt="CLS Caribe Legal Services" />
    </a>
    <ul class="nav-links">
      <li><a href={isSpanish ? '/' : '/en/'}>{isSpanish ? 'Inicio' : 'Home'}</a></li>
      <li><a href={isSpanish ? '/servicios' : '/en/services'}>{isSpanish ? 'Servicios' : 'Services'}</a></li>
      <li><a href={isSpanish ? '/nosotros' : '/en/about'}>{isSpanish ? 'Nosotros' : 'About'}</a></li>
      <li><a href={isSpanish ? '/contacto' : '/en/contact'}>{isSpanish ? 'Contacto' : 'Contact'}</a></li>
      <li class="lang-switch">
        <a href={isSpanish ? '/en/' : '/'}>{isSpanish ? 'EN' : 'ES'}</a>
      </li>
    </ul>
    <button class="mobile-menu-btn" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu">
  <ul>
    <li><a href={isSpanish ? '/' : '/en/'}>{isSpanish ? 'Inicio' : 'Home'}</a></li>
    <li><a href={isSpanish ? '/servicios' : '/en/services'}>{isSpanish ? 'Servicios' : 'Services'}</a></li>
    <li><a href={isSpanish ? '/nosotros' : '/en/about'}>{isSpanish ? 'Nosotros' : 'About'}</a></li>
    <li><a href={isSpanish ? '/contacto' : '/en/contact'}>{isSpanish ? 'Contacto' : 'Contact'}</a></li>
    <li class="lang-switch">
      <a href={isSpanish ? '/en/' : '/'}>{isSpanish ? 'English' : 'Español'}</a>
    </li>
  </ul>
</div>

<script>
  // Glassmorphism on scroll
  const header = document.getElementById('header');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;

    if (currentScroll > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const mobileBtn = document.querySelector('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');

  mobileBtn?.addEventListener('click', () => {
    mobileBtn.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
    document.body.classList.toggle('menu-open');
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileBtn?.classList.remove('active');
      mobileMenu?.classList.remove('active');
      document.body.classList.remove('menu-open');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    padding: 0.75rem 0;
    transition: all 0.4s ease;
    overflow: visible;
  }

  header.scrolled {
    background: rgba(40, 44, 45, 0.95);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    padding: 0.5rem 0;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    transition: all 0.4s ease;
  }

  header.scrolled nav {
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: flex-start;
    transition: all 0.4s ease;
    z-index: 1002;
  }

  .logo:hover {
    transform: scale(1.03);
  }

  .logo img {
    height: 135px;
    width: auto;
    transition: all 0.4s ease;
    filter: drop-shadow(0 10px 40px rgba(0, 0, 0, 0.6));
  }

  @media (min-width: 1025px) {
    .logo img {
      margin-left: -90px;
    }
  }

  header.scrolled .logo img {
    height: 50px;
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.3));
  }

  @media (max-width: 768px) {
    .logo img {
      height: 60px;
      margin-left: 0;
    }

    header.scrolled .logo img {
      height: 45px;
    }
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1025px) {
    .nav-links {
      margin-right: -120px;
    }
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #DEAA09;
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: #DEAA09;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .lang-switch a {
    background: rgba(222, 170, 9, 0.15);
    border: 1px solid rgba(222, 170, 9, 0.4);
    padding: 0.4rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: #DEAA09;
    transition: all 0.3s ease;
  }

  .lang-switch a::after {
    display: none;
  }

  .lang-switch a:hover {
    background: #DEAA09;
    color: #282C2D;
    border-color: #DEAA09;
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
  }

  .mobile-menu-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    transition: all 0.3s ease;
  }

  .mobile-menu-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile menu overlay */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    max-width: 350px;
    height: 100vh;
    background: rgba(40, 44, 45, 0.98);
    backdrop-filter: blur(20px);
    z-index: 999;
    transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 100px 2rem 2rem;
  }

  @media (max-width: 768px) {
    .mobile-menu {
      display: block;
    }
  }

  .mobile-menu.active {
    right: 0;
  }

  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mobile-menu a {
    color: #fff;
    font-size: 1.25rem;
    font-weight: 500;
    display: block;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .mobile-menu a:hover {
    color: #DEAA09;
    padding-left: 0.5rem;
  }

  .mobile-menu .lang-switch a {
    display: inline-block;
    background: rgba(222, 170, 9, 0.15);
    border: 1px solid #DEAA09;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  :global(body.menu-open) {
    overflow: hidden;
  }
</style>
