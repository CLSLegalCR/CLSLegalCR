---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="About Us | CLS Caribe Legal Services"
  description="Meet the team at CLS Caribe Legal Services. Experienced lawyers and consultants serving Southern Caribbean Costa Rica."
  lang="en"
>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>About Us</h1>
        <p>Meet the team behind CLS Caribe Legal Services</p>
      </div>
    </section>

    <!-- About Intro -->
    <section class="about-intro">
      <div class="container">
        <div class="intro-content fade-in">
          <h2>Who We Are</h2>
          <p>Caribe Legal Services is a law firm with solid legal experience and a clear strategic vision, focused on providing comprehensive, secure, and tailored legal solutions in Costa Rica's Caribbean region.</p>
          <p>We advise companies, national and international investors, and individuals, supporting them at every stage of the legal decision-making process through preventive legal counsel, sound legal structuring, and reliable representation. Our practice is grounded in professional ethics, transparency, confidentiality, and excellence &mdash; the core pillars of our firm.</p>
          <p>At Caribe Legal Services, we believe the law should not only resolve disputes, but also prevent risks, protect assets, and create value. Our commitment is to provide legal certainty and comprehensive support, acting as a trusted legal partner in a dynamic and constantly evolving environment, particularly in the real estate, corporate, labor, tax, and notarial sectors.</p>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="team-section">
      <div class="container">
        <div class="section-header fade-in">
          <h2>Our Team</h2>
          <p>Professionals committed to your success</p>
        </div>

        <div class="team-grid">
          <!-- Mario Andrés Hernández Bertarioni -->
          <div class="team-member fade-in">
            <div class="member-photo">
              <img src="/images/attorney-mario.png" alt="Mario Andrés Hernández Bertarioni" />
            </div>
            <div class="member-info">
              <h3>Mario Andrés Hernández Bertarioni</h3>
              <span class="member-title">Lawyer &amp; Notary</span>
              <p>Specialist in real estate, corporate, and labor law, supporting national and international investors with comprehensive legal counsel in Costa Rica's Caribbean region.</p>
              <a href="mailto:Andres@clslegalcr.com" class="member-email">Andres@clslegalcr.com</a>
            </div>
          </div>

          <!-- Javier Antonio Guerrero Alvarez -->
          <div class="team-member fade-in">
            <div class="member-photo">
              <img src="/images/attorney-javier.png" alt="Javier Antonio Guerrero Alvarez" />
            </div>
            <div class="member-info">
              <h3>Javier Antonio Guerrero Alvarez</h3>
              <span class="member-title">Lawyer &amp; Notary</span>
              <p>Specialist in real estate, corporate, and labor law, providing strategic legal solutions tailored to the needs of companies, investors, and individuals.</p>
              <a href="mailto:Javier@clslegalcr.com" class="member-email">Javier@clslegalcr.com</a>
            </div>
          </div>

          <!-- Rebeca Escalante -->
          <div class="team-member fade-in">
            <div class="member-photo member-photo--initials">
              <div class="initials-avatar">RE</div>
            </div>
            <div class="member-info">
              <h3>Rebeca Escalante</h3>
              <span class="member-title">Office Manager &amp; Brand Designer</span>
              <p>Keeps the firm running day to day — client coordination, scheduling, and office operations — and also designed the CLS brand identity: logo, color palette, typography, and visual guidelines.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="values-section">
      <div class="container">
        <div class="section-header fade-in">
          <h2>Our Values</h2>
        </div>

        <div class="values-grid">
          <div class="value-card fade-in">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Collaborative Teams</h3>
            <p>Working together to deliver effective legal solutions for every client.</p>
          </div>

          <div class="value-card fade-in">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
            </div>
            <h3>High-Performance</h3>
            <p>Legal efficiency in high-pressure environments — when the stakes are real.</p>
          </div>

          <div class="value-card fade-in">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h3>Client-Focused</h3>
            <p>Every legal strategy is built around the client's specific objectives.</p>
          </div>

          <div class="value-card fade-in">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h3>Ethical Standards</h3>
            <p>Absolute commitment to professional ethics, transparency, and confidentiality.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-card fade-in">
          <div class="cta-content">
            <h2>Ready to Work With Us?</h2>
            <p>Contact us for an initial consultation.</p>
          </div>
          <div class="cta-actions">
            <a href="/en/contact" class="cta-button primary">Contact Us</a>
            <a href="tel:+50660565736" class="cta-button secondary">
              +506 6056-5736
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .page-header {
    background: #282C2D;
    color: white;
    padding: 7rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #DEAA09;
  }

  .page-header p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* About Intro */
  .about-intro {
    padding: 3rem 0;
    background: transparent;
  }

  .about-intro > .container {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .intro-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-content h2 {
    font-size: 2rem;
    color: #282C2D;
    margin-bottom: 1.5rem;
  }

  .intro-content p {
    color: #555;
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  /* Team Section */
  .team-section {
    padding: 3rem 0;
    background: transparent;
  }

  .team-section > .container {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-size: 2rem;
    color: #282C2D;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: #666;
    font-size: 1.1rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .team-member {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .team-member:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  .member-photo {
    height: 260px;
    background: linear-gradient(135deg, #3a3e3f 0%, #282C2D 100%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .member-photo--initials {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .initials-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: #DEAA09;
    color: #282C2D;
    font-size: 2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.05em;
  }

  .member-photo img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .member-info {
    padding: 1.5rem;
  }

  .member-info h3 {
    font-size: 1.25rem;
    color: #282C2D;
    margin-bottom: 0.25rem;
  }

  .member-title {
    display: block;
    color: #DEAA09;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .member-info p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .member-email {
    display: inline-block;
    color: #DEAA09;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .member-email:hover {
    color: #b8900a;
  }

  /* Values Section */
  .values-section {
    padding: 3rem 0;
    background: transparent;
  }

  .values-section > .container {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .value-card {
    text-align: center;
    padding: 2rem 1.5rem;
    background: #f8f8f8;
    border-radius: 12px;
    transition: transform 0.3s ease;
  }

  .value-card:hover {
    transform: translateY(-3px);
  }

  .value-icon {
    color: #DEAA09;
    margin-bottom: 1rem;
  }

  .value-icon svg {
    width: 40px;
    height: 40px;
  }

  .value-card h3 {
    font-size: 1.1rem;
    color: #282C2D;
    margin-bottom: 0.5rem;
  }

  .value-card p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 2rem 0;
    background: #282C2D;
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(222, 170, 9, 0.1) 0%, rgba(222, 170, 9, 0.05) 100%);
    border: 1px solid rgba(222, 170, 9, 0.2);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }
  }

  .cta-content h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cta-actions {
      justify-content: center;
    }
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-button.primary {
    background: linear-gradient(135deg, #DEAA09 0%, #b8900a 100%);
    color: #282C2D;
  }

  .cta-button.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(222, 170, 9, 0.4);
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .cta-button.secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
