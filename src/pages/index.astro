---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="CLS Caribe Legal Services | Servicios Legales en el Caribe Sur"
  description="Soluciones legales y estratégicas personalizadas para empresas y particulares en el Caribe Sur de Costa Rica."
  lang="es"
>
  <!-- FAQ Schema for AEO -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuánto tiempo toma obtener la residencia en Costa Rica?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El proceso de residencia típicamente toma entre 6 a 12 meses, dependiendo del tipo de visa y la complejidad del caso. Trabajamos para agilizar cada trámite."
        }
      },
      {
        "@type": "Question",
        "name": "¿Pueden los extranjeros comprar propiedades en Costa Rica?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, los extranjeros tienen los mismos derechos de propiedad que los costarricenses. Es importante hacer un due diligence completo antes de comprar."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué tipos de visa de residencia existen en Costa Rica?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las opciones incluyen: Pensionado, Rentista, Inversionista, Vínculo con costarricense, y más. Cada una tiene requisitos específicos que evaluamos con usted."
        }
      },
      {
        "@type": "Question",
        "name": "¿Ofrecen consultas virtuales?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, ofrecemos consultas por videollamada para clientes que no pueden visitarnos en persona. Contáctenos para programar una cita virtual."
        }
      }
    ]
  }
  </script>

