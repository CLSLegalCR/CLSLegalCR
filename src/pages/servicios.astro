---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Servicios Legales | CLS Caribe Legal Services"
  description="Servicios legales en inmigración, bienes raíces, contratos y consultoría empresarial en el Caribe Sur de Costa Rica."
  lang="es"
>
  <Header lang="es" />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Servicios</h1>
        <p>Soluciones legales integrales para el Caribe Sur</p>
      </div>
    </section>

    <!-- Services -->
    <section class="services pattern-bg">
      <div class="container">

        <!-- Immigration -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Inmigración</h2>
            <p class="service-desc">Ayudamos a expatriados y extranjeros a establecerse legalmente en Costa Rica. Nuestro equipo le guía a través de cada paso del proceso migratorio.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Residencia temporal y permanente</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Residencia para pensionados y rentistas</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Permisos de trabajo</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Renovaciones y trámites migratorios</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Cédulas de residencia</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/immigration.jpg" alt="Inmigración" />
            </div>
          </div>
        </div>

        <!-- Real Estate -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Derecho Inmobiliario</h2>
            <p class="service-desc">Ofrecemos asesoría legal especializada a inversionistas extranjeros, proyectos turísticos y desarrollos inmobiliarios en la región Caribe de Costa Rica y a nivel nacional &mdash; garantizando certeza legal en cada etapa del proyecto.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Estudios registrales y due diligence integral</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Asesoría legal en compra y venta de propiedades</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Contratos inmobiliarios y fideicomisos</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Asesoría estratégica para inversionistas extranjeros</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Concesiones de zona marítimo terrestre</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-realestate.webp" alt="Bienes Raíces" />
            </div>
          </div>
        </div>

        <!-- Corporate -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Derecho Corporativo</h2>
            <p class="service-desc">Acompañamos a las empresas en su organización, cumplimiento y crecimiento &mdash; diseñando estructuras legales sólidas alineadas con los objetivos del negocio y los requerimientos regulatorios.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Constitución y reestructuración de sociedades</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Prácticas de gobierno corporativo</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Redacción y revisión de contratos comerciales</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Asesoría legal continua para empresas</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Apoyo legal a PYMES</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-corporate.webp" alt="Derecho Corporativo" />
            </div>
          </div>
        </div>

        <!-- Tax -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Derecho Tributario</h2>
            <p class="service-desc">Ofrecemos asesoría legal integral en derecho tributario, acompañando a empresas e inversionistas en la planificación fiscal, cumplimiento regulatorio y la gestión eficiente de sus obligaciones tributarias.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Planificación y diseño de estrategias fiscales</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Cumplimiento tributario y gestión fiscal</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Representación ante las Autoridades Tributarias</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Estrategias fiscales para proyectos e inversiones</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Optimización tributaria dentro del cumplimiento</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-tax.webp" alt="Impuestos" />
            </div>
          </div>
        </div>

        <!-- Labor Law -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Derecho Laboral</h2>
            <p class="service-desc">Brindamos asesoría legal preventiva en relaciones laborales, ayudando a empresas y empleadores a minimizar riesgos, cumplir con la normativa, y mantener relaciones laborales equilibradas y seguras.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Redacción y revisión de contratos laborales</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Reglamentos internos y políticas laborales</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Manejo de conflictos y procedimientos administrativos</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Defensa del empleador y asesoría legal</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Cumplimiento de leyes laborales</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-labor.webp" alt="Derecho Laboral" />
            </div>
          </div>
        </div>

        <!-- Environmental -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Derecho Ambiental</h2>
            <p class="service-desc">Entendemos la importancia de la sostenibilidad en nuestra región. Asesoramos en el cumplimiento de normativas ambientales, permisos y evaluaciones de impacto ambiental para proyectos de desarrollo.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Permisos ambientales</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Evaluaciones de impacto</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Cumplimiento normativo</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Proyectos de desarrollo sostenible</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Zona marítimo terrestre</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-environmental.webp" alt="Derecho Ambiental" />
            </div>
          </div>
        </div>

        <!-- Business Consulting -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Consultoría Empresarial</h2>
            <p class="service-desc">Además de los servicios legales, brindamos consultoría estratégica para identificar nuevas oportunidades, fomentar alianzas clave y promover el crecimiento de su negocio en el Caribe Sur.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Desarrollo de negocios</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Identificación de oportunidades</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Alianzas estratégicas</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Expansión empresarial</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Networking local</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-consulting.webp" alt="Consultoría Empresarial" />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-card fade-in">
          <div class="cta-content">
            <h2>¿Necesita Asesoría Legal?</h2>
            <p>Contáctenos para discutir su situación y encontrar la mejor solución.</p>
          </div>
          <div class="cta-actions">
            <a href="/contacto" class="cta-button primary">Contactar Ahora</a>
            <a href="tel:+50660565736" class="cta-button secondary">
              <span>📞</span> +506 6056-5736
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="es" />
</BaseLayout>

<style>
  .page-header {
    background: #282C2D;
    color: white;
    padding: 7rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #DEAA09;
  }

  .page-header p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Services */
  .services {
    padding: 2rem 0;
    background: transparent;
  }

  .services > .container {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .service-block {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
  }

  .service-block:last-of-type {
    border-bottom: none;
  }

  .service-block.reverse {
    grid-template-columns: 0.8fr 1.2fr;
  }

  .service-block.reverse .service-content {
    order: 2;
  }

  .service-block.reverse .service-visual {
    order: 1;
  }

  @media (max-width: 900px) {
    .service-block,
    .service-block.reverse {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-block.reverse .service-content,
    .service-block.reverse .service-visual {
      order: unset;
    }
  }

  .service-content h2 {
    font-size: 1.75rem;
    color: #282C2D;
    margin-bottom: 0.75rem;
  }

  .service-desc {
    color: #555;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #333;
    font-size: 1rem;
  }

  .list-icon {
    color: #DEAA09;
    font-weight: 600;
    font-size: 1.1rem;
  }

  .service-visual {
    display: flex;
    justify-content: center;
  }

  .service-image {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .service-image:hover {
    transform: scale(1.02);
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.2);
  }

  .service-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .service-image img {
      height: 180px;
    }
  }

  /* CTA Section */
  .cta-section {
    padding: 2rem 0;
    background: #282C2D;
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(222, 170, 9, 0.1) 0%, rgba(222, 170, 9, 0.05) 100%);
    border: 1px solid rgba(222, 170, 9, 0.2);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-card {
      flex-direction: column;
      text-align: center;
      padding: 2rem 1.5rem;
    }
  }

  .cta-content h2 {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cta-actions {
      justify-content: center;
    }
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-button.primary {
    background: linear-gradient(135deg, #DEAA09 0%, #b8900a 100%);
    color: #282C2D;
  }

  .cta-button.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(222, 170, 9, 0.4);
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .cta-button.secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
