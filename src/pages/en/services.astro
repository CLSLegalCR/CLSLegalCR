---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Legal Services | CLS Caribe Legal Services"
  description="Immigration, real estate, corporate law, and business consulting services in Southern Caribbean Costa Rica."
  lang="en"
>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Services</h1>
        <p>Comprehensive legal solutions for the Southern Caribbean</p>
      </div>
    </section>

    <!-- Services -->
    <section class="services pattern-bg">
      <div class="container">

        <!-- Immigration -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Immigration</h2>
            <p class="service-desc">We help expats and foreigners establish themselves legally in Costa Rica. Our team guides you through every step of the immigration process.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Temporary and permanent residency</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Pensionado and rentista visas</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Work permits</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Renewals and immigration procedures</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Residency ID cards (cédulas)</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/immigration.jpg" alt="Immigration" />
            </div>
          </div>
        </div>

        <!-- Real Estate -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Real Estate Law</h2>
            <p class="service-desc">We provide specialized legal counsel for foreign investors, tourism projects, and real estate developments in Costa Rica's Caribbean region and nationwide &mdash; ensuring legal certainty at every stage of the project.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Comprehensive title searches and due diligence</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Legal advice for purchase and sale transactions</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Real estate contracts and trusts</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Strategic counsel for foreign investors</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Maritime zone concessions</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-realestate.webp" alt="Real Estate" />
            </div>
          </div>
        </div>

        <!-- Corporate -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Corporate Law</h2>
            <p class="service-desc">We support companies in their organization, compliance, and growth &mdash; designing solid legal structures aligned with business objectives and regulatory requirements.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Company formation and restructuring</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Corporate governance practices</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Commercial contract drafting and review</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Ongoing legal counsel for businesses</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Legal support for SMEs</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-corporate.webp" alt="Corporate Law" />
            </div>
          </div>
        </div>

        <!-- Tax -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Tax Law</h2>
            <p class="service-desc">We offer comprehensive legal counsel in tax law, supporting companies and investors in tax planning, regulatory compliance, and the efficient management of their tax obligations.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Tax planning and strategy design</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Tax compliance and fiscal management</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Representation before the Tax Authorities</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Tax strategies for projects and investments</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Optimizing tax burden within compliance</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-tax.webp" alt="Tax Services" />
            </div>
          </div>
        </div>

        <!-- Labor Law -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Labor Law</h2>
            <p class="service-desc">We provide preventive legal advice in labor relations, helping companies and employers minimize risks, comply with regulations, and maintain balanced and secure employment relationships.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Employment contract drafting and review</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Internal regulations and labor policies</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Labor dispute handling and proceedings</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Employer defense and counsel</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Labor law compliance</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-labor.webp" alt="Labor Law" />
            </div>
          </div>
        </div>

        <!-- Environmental -->
        <div class="service-block reverse fade-in">
          <div class="service-content">
            <h2>Environmental Law</h2>
            <p class="service-desc">We understand the importance of sustainability in our region. We advise on environmental regulatory compliance, permits, and environmental impact assessments for development projects.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Environmental permits</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Impact assessments</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Regulatory compliance</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Sustainable development projects</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Maritime zone concessions</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-environmental.webp" alt="Environmental Law" />
            </div>
          </div>
        </div>

        <!-- Business Consulting -->
        <div class="service-block fade-in">
          <div class="service-content">
            <h2>Business Consulting</h2>
            <p class="service-desc">Beyond legal services, we provide strategic consulting to identify new opportunities, foster key alliances, and promote the growth of your business in the Southern Caribbean.</p>
            <ul class="service-list">
              <li>
                <span class="list-icon">→</span>
                <span>Business development</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Opportunity identification</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Strategic alliances</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Business expansion</span>
              </li>
              <li>
                <span class="list-icon">→</span>
                <span>Local networking</span>
              </li>
            </ul>
          </div>
          <div class="service-visual">
            <div class="service-image">
              <img src="/images/service-consulting.webp" alt="Business Consulting" />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-card fade-in">
          <div class="cta-content">
            <h2>Need Legal Advice?</h2>
            <p>Contact us to discuss your situation and find the best solution.</p>
          </div>
          <div class="cta-actions">
            <a href="/en/contact" class="cta-button primary">Contact Now</a>
            <a href="tel:+50660565736" class="cta-button secondary">
              <span>📞</span> +506 6056-5736
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .page-header {
    background: #282C2D;
    color: white;
    padding: 7rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #DEAA09;
  }

  .page-header p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Services */
  .services {
    padding: 2rem 0;
    background: transparent;
  }

  .services > .container {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .service-block {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
  }

  .service-block:last-of-type {
    border-bottom: none;
  }

  .service-block.reverse {
    grid-template-columns: 0.8fr 1.2fr;
  }

  .service-block.reverse .service-content {
    order: 2;
  }

  .service-block.reverse .service-visual {
    order: 1;
  }

  @media (max-width: 900px) {
    .service-block,
    .service-block.reverse {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-block.reverse .service-content,
    .service-block.reverse .service-visual {
      order: unset;
    }
  }

  .service-content h2 {
    font-size: 1.75rem;
    color: #282C2D;
    margin-bottom: 0.75rem;
  }

  .service-desc {
    color: #555;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #333;
    font-size: 1rem;
  }

  .list-icon {
    color: #DEAA09;
    font-weight: 600;
    font-size: 1rem;
  }

  .service-visual {
    display: flex;
    justify-content: center;
  }

  .service-image {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .service-image:hover {
    transform: scale(1.02);
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.2);
  }

  .service-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .service-image img {
      height: 180px;
    }
  }

  /* CTA Section */
  .cta-section {
    padding: 2rem 0;
    background: #282C2D;
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(222, 170, 9, 0.1) 0%, rgba(222, 170, 9, 0.05) 100%);
    border: 1px solid rgba(222, 170, 9, 0.2);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }
  }

  .cta-content h2 {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cta-actions {
      justify-content: center;
    }
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-button.primary {
    background: linear-gradient(135deg, #DEAA09 0%, #b8900a 100%);
    color: #282C2D;
  }

  .cta-button.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(222, 170, 9, 0.4);
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .cta-button.secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
